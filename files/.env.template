# MacroSignalTool — Environment Variables
# Copia questo file in .env e compila i valori reali
# NON committare mai .env su git (già in .gitignore)

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Necessario per classificazione news e strutturazione trade
# Ottieni su: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Telegram Bot (Phase 6.1) ─────────────────────────────────────────────────
# Come creare un bot:
#   1. Apri Telegram → cerca @BotFather
#   2. Invia /newbot → scegli nome e username
#   3. Copia il token che ti dà BotFather (formato: 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=

# Come trovare il CHAT_ID:
#   1. Avvia una chat con il tuo bot su Telegram
#   2. Apri: https://api.telegram.org/bot<TOKEN>/getUpdates nel browser
#   3. Copia il valore di "chat" → "id" dal primo messaggio (es. 123456789)
TELEGRAM_CHAT_ID=

# Soglia confidence per inviare alert Telegram (0.70 = 70%)
# Solo segnali con confidence >= questa soglia generano una notifica
TELEGRAM_SIGNAL_THRESHOLD=0.70

# ─── Email Digest Gmail (Phase 6.2) ───────────────────────────────────────────
# Indirizzo Gmail da cui inviare il digest
GMAIL_USER=tuo.indirizzo@gmail.com

# App Password Gmail (NON la password normale dell'account)
# Come ottenerla:
#   1. Vai su https://myaccount.google.com/security
#   2. Attiva la verifica in 2 passaggi (se non l'hai già)
#   3. Vai su https://myaccount.google.com/apppasswords
#   4. Seleziona "Altra app" → inserisci "MacroSignalTool" → Genera
#   5. Copia le 16 lettere mostrate (es. "abcd efgh ijkl mnop")
GMAIL_APP_PASSWORD=

# Indirizzo destinatario del digest giornaliero
# Lascia vuoto per usare lo stesso di GMAIL_USER (ti mandi il digest a te stesso)
DIGEST_RECIPIENT=

# ─── Paper Trading Config ─────────────────────────────────────────────────────
INITIAL_NAV=10000
MAX_POSITION_PCT=0.05
DB_PATH=paper_trading.db

# ─── App Settings ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000

# Intervallo di polling news (minuti). Default: 60 (ogni ora)
POLL_INTERVAL_MINUTES=60

# Intervallo aggiornamento prezzi (minuti). Default: 15
PRICE_UPDATE_INTERVAL_MINUTES=15
